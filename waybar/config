{
    "height": 0,
    //"position": "left",
    //"position": "bottom",
    "margin-left":0,
    "margin-right":0,
    "margin-bottom":-2,
    "margin-top":0,

    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],

    "modules-center": [
        "clock", 
    ],

    "modules-right": [
        "pulseaudio",
        "network",
        "memory",
        "temperature",
        "battery",
    ],

    "hyprland/window": {
      "format": "{}",
      "on-empty": "hidden",
      "tooltip": false,
      "max-length": 50,
      "rewrite":{
          "~":"kitty",
        },
    },
    
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      //"format-icons": {
      //  "active": "",
      //},
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      }
    },
    

    "mpris": {
      "format": "≤░ΟΘ {status_icon} {dynamic}",
      "interval": 0.5,
      "dynamic-len": 43,
	    "status-icons": {
		    "playing": "έΠ╕",
		    "paused": "έΨ╢",
		    "stopped": "ΎΒΞ"
	      },
	    "dynamic-order": ["title", "artist"],
      "ignored-players": ["firefox"]
    },


    "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%d %h %H:%M}"
    },


    "cpu": {
      "format": "ΎΜδ {usage}%",
      "tooltip": false
    },


    "memory": {
      "format": "Ό┐Ζ  {}%",
      "on-click": "kitty -- btop",
      "interval": 5
    },


    "temperature": {
      "critical-threshold": 75,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"]
    },


    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "≤▒ΡΜ {capacity}%",
      "format-plugged": "ΎΘο {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },


    "network": {
      "format-wifi": "{icon}  {essid}",
      "format-ethernet": "{cidr} ≤░ΙΒ",
      "tooltip-format": "{ifname} via {gwaddr} ≤░ΙΒ",
      "format-linked": "{ifname} (No IP) ≤░ΙΒ",
      "format-disconnected": "",
      "max-length": 11,
      "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
      "on-click": "kitty -- impala"
    },


    "pulseaudio": {
      "format": "{format_source}  {icon} {volume}%",
      "format-source": "",
      "format-source-muted": "ΎΕ▒ ",
      "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
      "format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
      "format-muted": "ΎΣο ",
      "format-icons": {
        "headphone": "ΎΑξ ",
        "hands-free": "ΎΨΡ",
        "headset": "ΎΑξ ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ "]
      },
      "on-click": "pavucontrol"
    },

    "custom/powermenu": {
      "format": "ΎΑΣ",
      "on-click": "$HOME/.scripts/toggle-powermenu.sh",
      "tooltip":false
    }
}
