{
    "height" : 28,
    "margin-right":4,
    "margin-top":3,

    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],

    "modules-center": [
        "hyprland/window"
    ],

    "modules-right": [
        "pulseaudio",
        "network",
        "memory",
        "battery",
        "clock",
        "custom/powermenu"
    ],

    "hyprland/window": {
      "format": "{}",
      "on-empty": "hidden",
      "tooltip": false,
      "max-length": 50,
    },
    
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      //"format-icons": {
      //  "active": "",
      //},
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      },
    },


    "mpris": {
      "format": "пАБ {status_icon} {dynamic}",
      "interval": 0.5,
      "dynamic-len": 40,
	    "status-icons": {
		    "playing": "вПЄ",
		    "paused": "вЦґ",
		    "stopped": "пБН"
	      },
	    "dynamic-order": ["title", "artist"],
    },


    "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },


    "cpu": {
      "format": "пЛЫ {usage}%",
      "tooltip": false
    },


    "memory": {
      "format": "оњЕ  {}%",
      "on-click": "kitty -- btop"
    },


    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}¬∞C",
      "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
    },


    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "у±РЛ {capacity}%",
      "format-plugged": "пЗ¶  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },


    "network": {
      "format-wifi": "пЗЂ  {essid}",
      "format-ethernet": "{cidr} пЮЦ",
      "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
      "format-linked": "{ifname} (No IP) пЮЦ",
      "format-disconnected": " вЪ† No connection",
      "on-click": "kitty -- nmtui"
    },


    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
      "format-bluetooth-muted": "у∞ЭЯ {icon}пКФ {format_source}",
      "format-muted": "пС¶",
      "format-icons": {
        "headphone": "пА•",
        "hands-free": "пЦР",
        "headset": "пЦР",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
        "default": ["пА¶", "пАІ", "пА®"]
      },
      "on-click": "pavucontrol"
    },

    "custom/powermenu": {
      "format": "пАС",
      "on-click": "$HOME/.config/rofi/powermenu/type-1/powermenu.sh",
      "tooltip":false,
    }
}
